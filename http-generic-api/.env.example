# ── Infrastructure ─────────────────────────────────────────────────────────────
PORT=8080
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=2

# ── Google Service Account (JSON string or file path) ──────────────────────────
# Paste the full service account JSON as a single-line string, or mount the file
# and set GOOGLE_APPLICATION_CREDENTIALS to its path.
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-sa.json

# ── Google Sheets — Spreadsheet IDs ────────────────────────────────────────────
REGISTRY_SPREADSHEET_ID=
ACTIVITY_SPREADSHEET_ID=      # defaults to REGISTRY_SPREADSHEET_ID if blank

# ── Google Drive ────────────────────────────────────────────────────────────────
OVERSIZED_ARTIFACTS_DRIVE_FOLDER_ID=

# ── Sheet names (override only if you renamed them) ────────────────────────────
# BRAND_REGISTRY_SHEET=Brand Registry
# ACTIONS_REGISTRY_SHEET=Actions Registry
# ENDPOINT_REGISTRY_SHEET=API Actions Endpoint Registry
# EXECUTION_POLICY_SHEET=Execution Policy Registry
# HOSTING_ACCOUNT_REGISTRY_SHEET=Hosting Account Registry
# SITE_RUNTIME_INVENTORY_REGISTRY_SHEET=Site Runtime Inventory Registry
# SITE_SETTINGS_INVENTORY_REGISTRY_SHEET=Site Settings Inventory Registry
# PLUGIN_INVENTORY_REGISTRY_SHEET=Plugin Inventory Registry
# TASK_ROUTES_SHEET=Task Routes
# WORKFLOW_REGISTRY_SHEET=Workflow Registry
# REGISTRY_SURFACES_CATALOG_SHEET=Registry Surfaces Catalog
# VALIDATION_REPAIR_REGISTRY_SHEET=Validation & Repair Registry
# EXECUTION_LOG_UNIFIED_SHEET=Execution Log Unified
# JSON_ASSET_REGISTRY_SHEET=JSON Asset Registry
# BRAND_CORE_REGISTRY_SHEET=Brand Core Registry

# ── Security ────────────────────────────────────────────────────────────────────
BACKEND_API_KEY=               # Required — all routes check Bearer <key>

# ── GitHub ──────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
# GITHUB_API_BASE_URL=https://api.github.com
# GITHUB_BLOB_CHUNK_MAX_LENGTH=100000

# ── Execution settings ──────────────────────────────────────────────────────────
# SERVICE_VERSION=2.5.0-wordpress-aware-migration
# JSON_BODY_LIMIT=20mb
# JOB_MAX_ATTEMPTS=3
# JOB_WEBHOOK_TIMEOUT_MS=10000
# JOB_QUEUE_NAME=http-generic-api
# EXECUTION_DEBUG=false
# HTTP_ALLOWED_TRANSPORT=
