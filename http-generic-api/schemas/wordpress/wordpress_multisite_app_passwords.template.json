{
  "config_version": "v1",
  "auth_type": "basic_auth_app_password",
  "header_name": "Authorization",
  "header_format": "Basic <base64(username:application_password)>",
  "selection_mode": "per_site",
  "selection_key": "brand_domain",
  "notes": [
    "Use one credential record per WordPress site.",
    "Usernames may be similar across sites, but each site keeps its own application password.",
    "Generate the Authorization header at runtime from username and application_password."
  ],
  "sites": [
    {
      "site_key": "dona_site_1",
      "brand_domain": "donatours.com",
      "wp_json_base": "https://donatours.com/wp-json",
      "username": "gpt",
      "application_password": "${DONATOURS_WP_APP_PASSWORD}",
      "auth_scope": "wordpress_api",
      "active": true,
      "notes": "One site = one app password"
    },
    {
      "site_key": "allroyal_site_2",
      "brand_domain": "allroyalegypt",
      "wp_json_base": "https://allroyalegypt.com/wp-json",
      "username": "gpt",
      "application_password": "${ALLROYALEGYPT_WP_APP_PASSWORD}",
      "auth_scope": "wordpress_api",
      "active": true,
      "notes": "Same or similar username allowed; password must be unique for this site"
    },
    {
      "site_key": "allmallah_site_2",
      "brand_domain": "tourism.almallahgroup-mg.com",
      "wp_json_base": "https://tourism.almallahgroup-mg.com/wp-json",
      "username": "gpt",
      "application_password": "${ALMALLAH_WP_APP_PASSWORD}",
      "auth_scope": "wordpress_api",
      "active": true,
      "notes": "Same or similar username allowed; password must be unique for this site"
    }
  ]
}