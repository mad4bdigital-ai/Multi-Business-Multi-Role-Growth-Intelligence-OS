{
  "config_version": "v1",
  "selection_mode": "by_target_key",
  "selection_key": "target_key",
  "default_timeout_seconds": 30,
  "header_blacklist": [
    "Authorization"
  ],
  "notes": [
    "Authorization must be generated by the system from the target credential block.",
    "Do not allow arbitrary full URLs from prompts; resolve base_url from target_key.",
    "Per-target credentials support multi-site WordPress and other approved APIs."
  ],
  "targets": [
    {
      "target_key": "donatours_wp",
      "display_name": "Dona Tours WordPress",
      "domain": "donatours.com",
      "base_url": "https://donatours.com/wp-json",
      "allowed_methods": [
        "GET",
        "POST",
        "PUT",
        "PATCH",
        "DELETE"
      ],
      "allowed_path_prefixes": [
        "/wp/v2/",
        "/wp-site-health/v1/",
        "/wp-block-editor/v1/",
        "/bulk-taxonomy-editor/v1/",
        "/code-snippets/v1/",
        "/fluentform/v1/",
        "/oembed/1.0/",
        "/batch/v1"
      ],
      "auth_type": "basic_auth_app_password",
      "credential_resolution": "per_target",
      "username": "gpt",
      "application_password": "${DONATOURS_WP_APP_PASSWORD}",
      "header_generation": "basic_base64_username_colon_password",
      "write_allowed": true,
      "destructive_allowed": false,
      "active": true,
      "notes": "Primary WordPress execution target"
    }
  ]
}